# Build artifacts and caches across all five reference languages.
# The companion ships source + tests only; everything here is regenerated by
# the one-command test run documented in each language's README.

# Python
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
.ruff_cache/
.venv/
venv/

# Java / Gradle
.gradle/
build/
*.class

# .NET
obj/
bin/

# Node / TypeScript
node_modules/
dist/

# Go
# (go test needs no ignored build output; binaries, if any, below)
*.out
